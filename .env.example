# Port the backend server will run on
PORT=5000

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/leads_db

# JWT Secret Key for authenticating sessions
JWT_SECRET=super_secret_jwt_key_please_change_in_production

# JWT Expiration Time (e.g., 7d for 7 days)
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS setup)
FRONTEND_URL=http://localhost:3000
